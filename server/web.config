<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="iisnode" path="bootstrap.cjs" verb="*" modules="iisnode" />
    </handlers>
    <rewrite>
      <rules>
        <rule name="ExpressApp" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="bootstrap.cjs" />
        </rule>
      </rules>
    </rewrite>
    <iisnode watchedFiles="web.config;bootstrap.cjs;src\*.js;src\routes\*.js;src\services\*.js;src\utils\*.js" />
  </system.webServer>
</configuration>
